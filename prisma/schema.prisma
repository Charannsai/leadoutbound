generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Session {
  id              String   @id @default(cuid())
  name            String
  searchQuery     String
  description     String?
  status          String   @default("draft") // draft, searching, qualifying, personalizing, reviewing, sending, completed, paused
  templateId      String?
  outboundChannel String   @default("email") // email, linkedin
  totalLeads      Int      @default(0)
  emailsSent      Int      @default(0)
  repliesCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  leads      Lead[]
  template   Template? @relation(fields: [templateId], references: [id])
  steps      SequenceStep[]
  leadStates LeadSequenceState[]
}

model Lead {
  id              String   @id @default(cuid())
  sessionId       String
  companyName     String
  companyWebsite  String?
  companySize     String?
  industry        String?
  location        String?
  contactName     String?
  contactEmail    String?
  contactTitle    String?
  contactLinkedin String?
  source          String?  // apify, manual, import
  qualificationScore Float?
  qualificationReason String?
  qualificationReport String?  // JSON string containing detailed scorecard
  outreachStrategy    String?  // JSON string containing outreach channel details
  applyDirect     Boolean  @default(false)
  pipelineStage   String   @default("generated") // generated, qualified, personalized, reviewed, approved, sent, replied, converted, rejected, bounced
  rawData         String?  // JSON string of all scraped data
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  session  Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  emails   LeadEmail[]
  replies  Reply[]

  sequenceStates LeadSequenceState[]
  callLogs       CallLog[]
  tasks          Task[]
  listLeads      ListLead[]
  deals          Deal[]
  meetings       Meeting[]
}

model LeadEmail {
  id            String   @id @default(cuid())
  leadId        String
  subject       String
  body          String
  htmlBody      String?
  status        String   @default("draft") // draft, approved, sent, failed, bounced
  emailType     String   @default("initial") // initial, followup_1, followup_2, followup_3
  gmailThreadId String?
  gmailMessageId String?
  sentAt        DateTime?
  openedAt      DateTime?
  aiReasoning   String?  // Why AI wrote this specific email
  attachments   String?  // JSON string of selected attachments: e.g. [{"id": "...", "name": "..."}]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lead  Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Template {
  id                String   @id @default(cuid())
  name              String
  category          String   // job_application, startup_founder, recruiter, freelance, agency, saas_sales, partnerships, investor, referral, general_bd
  description       String?
  subjectRules      String?  // Instructions for generating subject lines
  bodyInstructions  String?  // Instructions for generating email body
  tone              String   @default("professional") // professional, casual, enthusiastic, formal
  followUpEnabled   Boolean  @default(true)
  followUpCount     Int      @default(2)
  followUpDelayDays Int      @default(3)
  followUpInstructions String?
  attachResume      Boolean  @default(false)
  attachPortfolio   Boolean  @default(false)
  aiPromptOverride  String?
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  sessions Session[]
}

model KnowledgeEntry {
  id        String   @id @default(cuid())
  category  String   // personal, skills, experience, links, pricing, availability, notes
  label     String
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KnowledgeFile {
  id        String   @id @default(cuid())
  name      String
  filename  String
  filepath  String
  fileType  String   // resume, portfolio, cover_letter, other
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reply {
  id            String   @id @default(cuid())
  leadId        String
  gmailThreadId String?
  gmailMessageId String?
  subject       String?
  body          String
  fromEmail     String
  fromName      String?
  classification String? // positive_interest, interview, pricing, info_request, auto_response, rejection, bounce, spam
  isRead        Boolean  @default(false)
  receivedAt    DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model SavedSearch {
  id        String   @id @default(cuid())
  name      String
  filters   String   // JSON string of filters
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomList {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leads       ListLead[]
}

model ListLead {
  id         String   @id @default(cuid())
  listId     String
  leadId     String
  createdAt  DateTime @default(now())

  list       CustomList @relation(fields: [listId], references: [id], onDelete: Cascade)
  lead       Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([listId, leadId])
}

model SequenceStep {
  id          String   @id @default(cuid())
  sessionId   String
  stepNumber  Int
  type        String   // email_auto, email_manual, linkedin_connect, call, task
  templateId  String?
  delayDays   Int      @default(0)
  instructions String?
  subject     String?
  body        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model LeadSequenceState {
  id                 String   @id @default(cuid())
  leadId             String
  sessionId          String
  currentStepNumber  Int      @default(1)
  status             String   @default("active") // active, paused, completed, replied
  nextRunAt          DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lead               Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  session            Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([leadId, sessionId])
}

model CallLog {
  id        String   @id @default(cuid())
  leadId    String
  outcome   String   // connected, busy, no_answer, meeting_scheduled, left_voicemail
  notes     String?
  duration  Int      @default(0) // in seconds
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Task {
  id          String   @id @default(cuid())
  leadId      String
  type        String   // email_manual, call, linkedin, task
  title       String
  description String?
  dueDate     DateTime @default(now())
  status      String   @default("pending") // pending, completed, skipped
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Deal {
  id        String   @id @default(cuid())
  name      String
  amount    Float    @default(0.0)
  stage     String   @default("prospecting") // prospecting, qualified, proposal, won, lost
  leadId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Meeting {
  id        String   @id @default(cuid())
  title     String
  startTime DateTime
  endTime   DateTime
  leadId    String
  status    String   @default("scheduled") // scheduled, completed, cancelled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Workflow {
  id        String   @id @default(cuid())
  name      String
  trigger   String   // lead_replied, deal_created, call_logged, email_opened
  action    String   // move_deal, create_task, send_slack, update_lead
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
